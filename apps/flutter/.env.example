# Whist Flutter app – local dev env (optional)
# Override at run/build time with --dart-define instead:
#   flutter run --dart-define=API_URL=http://localhost:8000/api/v1 --dart-define=AUTH_URL=https://...
#
# API base URL (same backend as Angular / Whist API)
API_URL=http://localhost:8000/api/v1
#
# Neon Auth URL (from Neon Dashboard → Users → Configuration → Auth URL)
AUTH_URL=https://ep-shiny-voice-agz9vcbc.neonauth.c-2.eu-central-1.aws.neon.tech/neondb/auth
