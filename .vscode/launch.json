{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter: Debug",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/flutter_mobile"
    },
    {
      "name": "Flutter: Attach",
      "type": "dart",
      "request": "attach",
      "cwd": "${workspaceFolder}/flutter_mobile"
    },
    {
      "name": "Backend: Dev (Local PostgreSQL)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "jinja": true,
      "justMyCode": false,
      "cwd": "${workspaceFolder}/backend",
      "env": { "PYTHONPATH": "${workspaceFolder}/backend" },
      "envFile": "${workspaceFolder}/backend/.env",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/backend/.venv/bin/python3",
      "gevent": false,
      "subProcess": true
    },
    {
      "name": "Backend: Production (Neon)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "jinja": true,
      "justMyCode": false,
      "cwd": "${workspaceFolder}/backend",
      "env": { "PYTHONPATH": "${workspaceFolder}/backend" },
      "envFile": "${workspaceFolder}/backend/.env.prod",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/backend/.venv/bin/python3",
      "subProcess": true
    },
    {
      "name": "Frontend: Serve (Dev → localhost:8000)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start",
      "cwd": "${workspaceFolder}/angular-web"
    },
    {
      "name": "Frontend: Serve (Prod API → whist.api.orbasker.com)",
      "type": "node-terminal",
      "request": "launch",
      "command": "API_URL=https://whist.api.orbasker.com/api/v1 npm run start",
      "cwd": "${workspaceFolder}/angular-web"
    },
    {
      "name": "Frontend: Chrome Debug",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/angular-web/src",
      "sourceMapPathOverrides": {
        "webpack:/*": "${webRoot}/*",
        "/./*": "${webRoot}/*",
        "/src/*": "${webRoot}/*",
        "/*": "*",
        "/./~/*": "${workspaceFolder}/node_modules/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: BE (prod DB) + FE",
      "configurations": [
        "Backend: Dev (Local PostgreSQL)",
        "Frontend: Serve (Dev → localhost:8000)"
      ]
    },
    {
      "name": "Frontend: Debug (Prod API)",
      "configurations": [
        "Frontend: Serve (Prod API → whist.api.orbasker.com)",
        "Frontend: Chrome Debug"
      ]
    }
  ]
}
