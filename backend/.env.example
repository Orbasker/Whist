# Database
# For PostgreSQL (recommended for production):
# Format: postgresql://username:password@localhost:5432/database_name
# If no password, use: postgresql://username@localhost:5432/database_name
DATABASE_URL=postgresql://localhost:5432/whist_db

# For SQLite (development - simpler, no setup needed):
# DATABASE_URL=sqlite:///./whist.db

# API
API_V1_PREFIX=/api/v1
PROJECT_NAME=Whist Game API

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Supabase Realtime (optional). If the frontend uses Supabase Realtime, set these in backend .env
# so that REST-triggered updates (e.g. submit_bids, submit_tricks) are broadcast to all clients.
# SUPABASE_URL=https://<project_ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role_key_from_project_settings_api>
